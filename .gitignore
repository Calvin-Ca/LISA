**/__pycache__
.DS_Store
/runs/
.vscode/
data/
data_by_category/

# 数据合成 pipeline 的生成物 / 原料(保留目录结构,忽略内容)
data_pipeline/ingest/*
data_pipeline/raw/*
data_pipeline/out/*
data_pipeline/vis/*
!data_pipeline/**/.gitkeep

# LISA 训练数据(样本不入库,保留目录骨架)
dataset/reason_seg/ReasonSeg/train/*
dataset/reason_seg/ReasonSeg/val/*
dataset/reason_seg/ReasonSeg/explanatory/*
!dataset/**/.gitkeep
!dataset/README.md

# 实验结果
benchmark/
benchmark_outputs/

# exp 台账保留文本/指标文件,忽略 outputs 中的大量图片
exp/runs/*/outputs/**/*.png
exp/runs/*/outputs/**/*.jpg
exp/runs/*/outputs/**/*.jpeg
exp/runs/*/outputs/**/*.webp
exp/runs/*/outputs/**/*.bmp
exp/runs/*/outputs/**/*.gif
exp/runs/*/outputs/**/*.tif
exp/runs/*/outputs/**/*.tiff

# SAM / GroundingDINO 权重
*.pth
